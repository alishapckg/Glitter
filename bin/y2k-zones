#!/usr/bin/env python3
"""
Y2K Zones - Final Working Version (with bounds checking)
"""

import sys
import os
import argparse
import subprocess
import shutil
import threading
from pathlib import Path

import cv2
import numpy as np


# Auto-install dependencies
try:
    import cv2; import numpy
except ImportError:
    os.system(f"{sys.executable} -m pip install opencv-python numpy --user")
    print("Restarting..."); os.execl(sys.executable, sys.executable, *sys.argv)

import cv2; import numpy as np


class App:
    def __init__(self, video_path):
        self.input_path = Path(video_path)
        self.cap = cv2.VideoCapture(str(video_path))
        
        if not self.cap.isOpened():
            raise ValueError("Cannot open video")
        
        self.fps = self.cap.get(cv2.CAP_PROP_FPS)
        self.total = int(self.cap.get(cv2.CAP_PROP_FRAME_COUNT))
        self.w = int(self.cap.get(cv2.CAP_PROP_FRAME_WIDTH))
        self.h = int(self.cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
        
        ret, self.frame = self.cap.read()
        if not ret:
            raise ValueError("Cannot read frame")
        
        self.orig = self.frame.copy()
        
        # Settings
        self.mask = np.zeros((self.h, self.w), dtype=np.uint8)
        self.brush = 30
        self.blur_val = 50
        
        # State
        self.drawing = False
        self.last = None
        self.mp = (0, 0)
        
        # Canvas
        self.panel_w = 320
        self.cw = self.w + self.panel_w
        self.ch = max(self.h, 500)
        self.canvas = np.zeros((self.ch, self.cw, 3), dtype=np.uint8)
        self.win = "Y2K Zones"
        self.running = True
    
    def draw_panel(self):
        p = self.canvas[:, self.w:]
        p[:] = (35, 28, 45)
        x = 15
        
        # Title
        cv2.putText(p, "✨ Y2K ZONES", (x, 32), 
                   cv2.FONT_HERSHEY_SIMPLEX, 0.6, (255, 105, 180), 2)
        
        # Settings box
        cv2.rectangle(p, (x-5, 48), (x+310, 140), (50, 45, 60), -1)
        
        cv2.putText(p, f"🖌️ Brush: {self.brush}px", (x, 70),
                   cv2.FONT_HERSHEY_SIMPLEX, 0.48, (255, 215, 100), 1)
        
        cv2.putText(p, f"💫 Blur: {self.blur_val}%", (x, 98),
                   cv2.FONT_HERSHEY_SIMPLEX, 0.48, (255, 182, 193), 1)
        
        cv2.putText(p, f"🎭 Mask: {np.count_nonzero(self.mask):,} px", (x, 126),
                   cv2.FONT_HERSHEY_SIMPLEX, 0.45, (150, 230, 255), 1)
        
        # Commands
        cv2.putText(p, "── Terminal Commands ──", (x, 165),
                   cv2.FONT_HERSHEY_SIMPLEX, 0.4, (255, 105, 180), 1)
        
        cmds = [
            ("brush N", "Set brush size"),
            ("blur N", "Set blur strength"),
            ("clear", "Clear mask"),
            ("done", "Process & save"),
            ("exit", "Cancel"),
        ]
        
        for i, (cmd, desc) in enumerate(cmds):
            y = 195 + i * 24
            cv2.putText(p, f"  {cmd}", (x, y), cv2.FONT_HERSHEY_SIMPLEX, 0.42, (200, 195, 210), 1)
            cv2.putText(p, f"{desc}", (x + 95, y), cv2.FONT_HERSHEY_SIMPLEX, 0.36, (140, 135, 155), 1)
        
        # Bottom status
        by = self.ch - 28
        cv2.rectangle(p, (x-5, by-12), (x+310, self.ch-3), (40, 35, 50), -1)
        cv2.putText(p, "🖱️ Drag to paint | Scroll: brush | Type commands below", 
                   (x, by+5), cv2.FONT_HERSHEY_SIMPLEX, 0.36, (180, 175, 195), 1)
    
    def render(self):
        # Composite frame with mask overlay
        disp = self.frame.copy()
        disp[self.mask > 0] = [80, 255, 160]
        self.canvas[:self.h, :self.w] = disp
        
        # Draw panel
        self.draw_panel()
        
        # Draw cursor (only if within bounds!)
        mx, my = self.mp
        if 0 <= mx < self.w and 0 <= my < self.h:
            ov = self.canvas[:self.h, :self.w].copy()
            cv2.circle(ov, (mx, my), self.brush, (255, 255, 255), 1)
            cv2.circle(ov, (mx, my), self.brush, (255, 105, 180), 2)
            cs = min(8, self.brush // 3)
            cv2.line(ov, (mx-cs, my), (mx+cs, my), (255, 255, 255), 1)
            cv2.line(ov, (mx, my-cs), (mx, my+cs), (255, 255, 255), 1)
            self.canvas[:self.h, :self.w] = cv2.addWeighted(
                ov, 0.35, self.canvas[:self.h, :self.w], 0.65, 0
            )
        
        cv2.imshow(self.win, self.canvas)
    
    def _paint(self, x, y):
        """Paint on mask with bounds checking"""
        # Check bounds for current point
        if not (0 <= x < self.w and 0 <= y < self.h):
            return
        
        # Draw circle at current position
        cv2.circle(self.mask, (x, y), self.brush, 255, -1)
        
        # Draw line from last point (with bounds check)
        if self.last is not None:
            lx, ly = self.last
            # Only draw line if last point was also in bounds
            if 0 <= lx < self.w and 0 <= ly < self.h:
                # Use fixed small thickness to avoid OpenCV error
                cv2.line(self.mask, self.last, (x, y), 3, -1)
        
        # Update last point
        self.last = (x, y)
    
    def on_mouse(self, event, x, y, flags, param):
        """Mouse callback with bounds checking"""
        if not self.running:
            return
        
        # Always update mouse position (for cursor display)
        self.mp = (x, y)
        
        # Check if over video area
        over_video = (0 <= x < self.w and 0 <= y < self.h)
        
        if event == cv2.EVENT_MOUSEMOVE:
            if self.drawing and over_video:
                # Paint with bounds checking
                self._paint(x, y)
                
        elif event == cv2.EVENT_LBUTTONDOWN:
            if over_video:
                # Start drawing only if in bounds
                self.drawing = True
                self.last = (x, y)
                self._paint(x, y)
            # If click outside video area - ignore (don't start drawing)
                
        elif event == cv2.EVENT_LBUTTONUP:
            # Stop drawing
            self.drawing = False
            self.last = None
            
        elif event == cv2.EVENT_MOUSEWHEEL:
            # Change brush size (works anywhere)
            if flags > 0:
                self.brush = min(150, max(5, self.brush + 3))
            else:
                self.brush = min(150, max(5, self.brush - 3))
            
            # Print status so user sees it works
            sys.stdout.write(f'\r  🖌️ {self.brush}px | 💫 {self.blur_val}% | 🎭 {np.count_nonzero(self.mask):,}px{" "*10}')
            sys.stdout.flush()
    
    def process_video(self):
        """Process video with blur effect"""
        # Determine output path
        out_path = self.input_path.with_name(f"{self.input_path.stem}_y2k.mp4")
        if len(sys.argv) > 2:
            out_path = Path(sys.argv[2])
        
        print(f"\n{'='*55}")
        print(f"  Processing: {self.input_path.name}")
        print(f"  Output: {out_path.name}")
        print(f"  Blur: {self.blur_val}% | Mask: {np.count_nonzero(self.mask):,} pixels")
        print(f"{'='*55}\n")
        
        # Calculate blur kernel size
        ksize = int(3 + (self.blur_val / 100) * 29)
        if ksize % 2 == 0:
            ksize += 1
        ksize = max(3, min(ksize, 31))  # Clamp to valid range
        
        # Setup video writer
        fourcc = cv2.VideoWriter_fourcc(*'mp4v')
        out = cv2.VideoWriter(str(out_path), fourcc, self.fps, (self.w, self.h))
        
        # Reset to beginning
        self.cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
        
        # Process each frame
        for i in range(self.total):
            ret, frame = self.cap.read()
            if not ret:
                break
            
            # Apply blur where mask exists
            if np.any(self.mask):
                blurred = cv2.GaussianBlur(frame, (ksize, ksize), 0)
                mask_3ch = cv2.merge([self.mask] * 3)
                result = np.where(mask_3ch > 0, blurred, frame)
                out.write(result)
            else:
                out.write(frame)
            
            # Progress update (every 10 frames to avoid slowdown)
            if i % 10 == 0 or i == self.total - 1:
                pct = (i + 1) / self.total * 100
                filled = int(45 * i / self.total)
                bar = '█' * filled + '░' * (45 - filled)
                sys.stdout.write(f'\r  [{bar}] {pct:5.1f}% ({i+1}/{self.total})')
                sys.stdout.flush()
        
        out.release()
        print(f"\n\n✓ Video saved to: {out_path}")
        
        # Try to attach audio
        self._attach_audio(out_path)
    
    def _attach_audio(self, video_path):
        """Extract audio from source and merge using ffmpeg"""
        print("\n  Attaching audio...")
        
        temp_file = video_path.with_suffix('.temp.mp4')
        
        try:
            cmd = [
                'ffmpeg', '-y',
                '-i', str(video_path),
                '-i', str(self.input_path),
                '-map', '0:v',
                '-map', '1:a?',
                '-c:v', 'copy',
                '-c:a', 'aac',
                '-shortest',
                str(temp_file)
            ]
            
            result = subprocess.run(cmd, capture_output=True, text=True)
            
            if result.returncode == 0:
                shutil.move(str(temp_file), str(video_path))
                print("  ✓ Audio attached successfully!")
            else:
                print("  ⚠ Could not attach audio (video saved without audio)")
                if temp_file.exists():
                    temp_file.unlink()
                    
        except FileNotFoundError:
            print("  ⚠ ffmpeg not found. Install with: brew install ffmpeg")
            print("  Video saved but without audio track")
        except Exception as e:
            print(f"  ⚠ Error attaching audio: {e}")
    
    def run(self):
        """Main editor loop"""
        print("\n" + "=" * 55)
        print("  ✨ Y2K Zones - Terminal Command Mode")
        print("=" * 55)
        print(f"\n  Video: {self.input_path.name}")
        print(f"  Resolution: {self.w} × {self.h} | Frames: {self.total}\n")
        print("  ⌨️  Type commands in terminal (window is open)\n")
        
        # Create window
        cv2.namedWindow(self.win, cv2.WINDOW_NORMAL)
        cv2.setMouseCallback(self.win, self.on_mouse)
        cv2.resizeWindow(self.win, self.cw, min(self.ch, 700))
        
        # Start command listener thread
        def command_listener():
            while self.running:
                try:
                    cmd_input = input("\nCommand> ").strip().lower()
                    
                    if not cmd_input:
                        continue
                    
                    parts = cmd_input.split()
                    action = parts[0]
                    
                    if action == 'brush' and len(parts) > 1:
                        try:
                            val = int(parts[1])
                            self.brush = max(5, min(150, val))
                            print(f"  ✓ Brush size set to: {self.brush}px")
                        except ValueError:
                            print("  ⚠ Invalid number. Usage: brush <size>")
                            
                    elif action == 'blur' and len(parts) > 1:
                        try:
                            val = int(parts[1])
                            self.blur_val = max(1, min(100, val))
                            print(f"  ✓ Blur strength set to: {self.blur_val}%")
                        except ValueError:
                            print("  ⚠ Invalid number. Usage: blur <value>")
                            
                    elif action == 'clear':
                        self.mask[:] = 0
                        print("  ✓ Mask cleared")
                        
                    elif action == 'undo':
                        # Simple undo: erode mask slightly
                        kernel_size = max(5, self.brush * 2)
                        kernel = np.ones((kernel_size, kernel_size), np.uint8)
                        self.mask = cv2.erode(self.mask, kernel, iterations=1)
                        print("  ✓ Undo (eroded mask)")
                        
                    elif action in ['done', 'save', 'enter']:
                        self.running = False
                        print(f"\n  Starting processing...")
                        
                    elif action in ['exit', 'quit', 'cancel']:
                        self.running = False
                        print("\n  ✗ Cancelled by user")
                        
                    elif action == 'help':
                        print("""
  Available commands:
  
    brush <size>     Set brush size (5-150)
                     Example: brush 40
  
    blur <value>    Set blur strength (1-100)
                     Example: blur 75
  
    clear           Clear the entire mask
  
    undo            Undo last stroke (erode)
  
    done / save     Process video and save
                  Output: <input>_y2k.mp4
  
    exit / cancel   Exit without saving
  
  Mouse controls:
    • Left-click + drag: Paint mask area
    • Scroll wheel: Change brush size
                        """)
                    else:
                        print(f"  ? Unknown command: '{action}'. Type 'help' for available commands")
                        
                except EOFError:
                    # EOF when terminal closes
                    self.running = False
                    break
                except KeyboardInterrupt:
                    self.running = False
                    break
                except Exception as e:
                    print(f"  Error: {e}")
        
        # Start thread
        t = threading.Thread(target=command_listener, daemon=True)
        t.start()
        
        # Main render loop
        while self.running:
            self.render()
            
            key = cv2.waitKey(30) & 0xFF
            
            if key == 27:  # ESC key
                self.running = False
                print("\n  ✗ Cancelled (ESC pressed)")
                break
                
            elif key == 13:  # Enter key
                self.running = False
                print(f"\n  ✓ Enter pressed - processing...")
        
        # Cleanup
        self.cap.release()
        cv2.destroyAllWindows()
        
        # Process video if done normally (not cancelled)
        if np.count_nonzero(self.mask) > 0 or True:  # Always process for now
            self.process_video()


def main():
    """Main entry point"""
    parser = argparse.ArgumentParser(
        description='Y2K Zones - Apply Y2K blur effect to video',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  %(prog)s video.mov
  %(prog)s video.mov output.mp4

Commands (type in terminal after window opens):
  brush 40       Set brush size to 40 pixels
  blur 70        Set blur strength to 70%
  clear          Clear painted mask
  done           Process and save video
        """
    )
    
    parser.add_argument('input', help='Input video file path')
    parser.add_argument('output', nargs='?', help='Output file path (optional)')
    
    args = parser.parse_args()
    
    # Validate input file exists
    if not Path(args.input).exists():
        print(f"Error: Input file not found: {args.input}", file=sys.stderr)
        sys.exit(1)
    
    try:
        app = App(args.input)
        app.run()
    except Exception as e:
        print(f"\nError: {e}", file=sys.stderr)
        import traceback
        traceback.print_exc()
        sys.exit(1)


if __name__ == '__main__':
    main()
